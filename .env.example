# ── AI Provider (Required) ─────────────────────────────────────────────
# Google Gemini 2.5 Flash — supports multimodal (text, image, log, video)
# Get key at: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here
# Model: gemini-2.5-flash (default, recommended) or gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash

# ── Observability (Required for full tracing) ──────────────────────────
# Get free account at: https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ── Database (Auto-configured by docker-compose) ───────────────────────
# Only needed if running backend outside Docker
# DATABASE_URL=postgresql://sre_user:sre_pass@localhost:5432/sre_triage

# ── Optional: OpenRouter alternative (OpenAI-compatible) ──────────────
# Uncomment and set GEMINI_MODEL=openai/google/gemini-2.0-flash if using OpenRouter
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
