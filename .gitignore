# ── Secrets — NEVER commit ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*_secret*
*_credentials*

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.Python
*.egg-info/
dist/
build/
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# ── Docker ────────────────────────────────────────────────────────────────────
# (docker-compose.yml is intentionally tracked)

# ── Uploads (runtime user data) ──────────────────────────────────────────────
backend/uploads/
*.upload

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
# (evidence/*.log are intentionally tracked as demo artifacts)
!evidence/

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
pgdata/

# ── Misc ─────────────────────────────────────────────────────────────────────
tmp/
.tmp/
*.bak
*.orig
