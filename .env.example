# ── AI Provider (Required) ─────────────────────────────────────────────
# Google Gemini 2.5 Flash — supports multimodal (text, image, log, video)
# Get key at: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here
# Model: gemini-2.5-flash (default, recommended) or gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash

# ── Observability (Required for full tracing) ──────────────────────────
# Get free account at: https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ── Slack (Real webhook — get at api.slack.com/apps) ──────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Jira (Real REST API — get token at id.atlassian.com/manage-profile/security) ──
JIRA_SITE_URL=your-site.atlassian.net
JIRA_USER_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_PROJECT_KEY=SRE

# ── Email / SMTP (Mailhog — local mail catcher, auto-configured by Docker) ──
# In Docker: mailhog:1025 (no changes needed)
# Locally: localhost:1025 (run mailhog separately)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=sre-agent@agentx.local
SRE_TEAM_EMAIL=sre-team@agentx.local

# ── Database (Auto-configured by docker-compose) ───────────────────────
# Only needed if running backend outside Docker
# DATABASE_URL=postgresql://sre_user:sre_pass@localhost:5432/sre_triage
